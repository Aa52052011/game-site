# Set in Vercel → Project → Settings → Environment Variables (Production)
# Required for /stats login: ADMIN_STATS_PASSWORD, STATS_SESSION_SECRET
# Required for event tracking: Vercel Blob Store (auto-injects BLOB_READ_WRITE_TOKEN)
NEXT_PUBLIC_SITE_URL=https://get1xplay.com

# Stats admin — /stats page login password (choose your own, no leading/trailing spaces)
ADMIN_STATS_PASSWORD=your-strong-password

# Random secret for stats session cookie (any long random string, no spaces)
STATS_SESSION_SECRET=change-this-to-a-long-random-string

# --- Vercel Blob (required for /stats data tracking) ---
# Do NOT add manually. In Vercel Dashboard:
#   Storage → Create → Blob → Connect to this project → Redeploy
# Vercel will auto-create:
# BLOB_READ_WRITE_TOKEN=
